# openclaw.plugin.template.json + package.json version)
openclaw.plugin.json

# Test coverage
coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*

