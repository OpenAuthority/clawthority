data/

# Build-time generated file — baked by scripts/gen-build-info.mjs
src/build-info.ts

# npm pack artifacts — built by `npm pack`, distributed via releases not git
*.tgz

# Claude
.claude/

# Local HITL policy — user-specific, not committed
hitl-policy.yaml
