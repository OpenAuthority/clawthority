{
  "version": 2,
  "rules": [
    {
      "effect": "permit",
      "action_class": "filesystem.read",
      "reason": "Filesystem read operations are permitted for all agents",
      "tags": [
        "filesystem",
        "read-only"
      ]
    },
    {
      "effect": "permit",
      "action_class": "web.search",
      "reason": "Web search operations are permitted for all agents",
      "tags": [
        "web",
        "search"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(fetch|browser|http_get|web_fetch|get_url|fetch_url|http_request|curl|wget|download_url|http_head|head_url|http_options)$",
      "priority": 90,
      "reason": "Outbound HTTP fetch requires human-in-the-loop approval",
      "tags": [
        "web",
        "fetch",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(write|edit|apply_patch|write_file|writefile|create_file|save_file|update_file|edit_file|patch_file|make_dir|mkdir|create_dir|create_directory|copy_file|copy|cp|duplicate_file|move_file|mv|move|rename_file|rename|tee|touch)$",
      "priority": 90,
      "reason": "Filesystem write operations require human-in-the-loop approval",
      "tags": [
        "filesystem",
        "write",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(delete_file|deletefile|remove_file|rm_file|unlink_file|rm|unlink|delete|remove|move_to_trash|trash|shred|rmdir)$",
      "priority": 90,
      "reason": "Filesystem delete operations require human-in-the-loop approval",
      "tags": [
        "filesystem",
        "delete",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(message|call_webhook|webhook|trigger_webhook|post_webhook|send_notification)$",
      "priority": 90,
      "reason": "Sending messages requires human-in-the-loop approval",
      "tags": [
        "communication",
        "send",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(send_email|email_send|send_mail|compose_email|email)$",
      "priority": 90,
      "reason": "Sending email requires human-in-the-loop approval",
      "tags": [
        "communication",
        "email",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(pay|payment|initiate_payment|create_payment|charge|stripe_payment)$",
      "priority": 90,
      "reason": "Payment initiation requires human-in-the-loop approval",
      "tags": [
        "payment",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(read_secret|get_secret|get_credential|retrieve_secret|read_credential)$",
      "priority": 90,
      "reason": "Credential reads require human-in-the-loop approval",
      "tags": [
        "credential",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "resource": "tool",
      "match": "^(write_secret|set_secret|set_credential|store_secret|create_secret)$",
      "priority": 90,
      "reason": "Credential write operations require human-in-the-loop approval",
      "tags": [
        "credential",
        "hitl"
      ]
    },
    {
      "effect": "forbid",
      "action_class": "shell.exec",
      "reason": "Shell execution requires human-in-the-loop approval",
      "tags": [
        "system",
        "security",
        "hitl"
      ],
      "priority": 90
    },
    {
      "effect": "forbid",
      "action_class": "code.execute",
      "reason": "Arbitrary code execution is unconditionally forbidden",
      "tags": [
        "system",
        "security"
      ]
    },
    {
      "effect": "forbid",
      "intent_group": "destructive_fs",
      "reason": "Destructive filesystem operations are unconditionally forbidden",
      "tags": [
        "filesystem",
        "security"
      ]
    },
    {
      "effect": "forbid",
      "intent_group": "data_exfiltration",
      "priority": 90,
      "reason": "Data exfiltration operations require human-in-the-loop approval",
      "tags": [
        "web",
        "security",
        "data-exfiltration",
        "hitl"
      ]
    }
  ],
  "checksum": "f3003f89f9c21b3767aed601066246e89f61888026bf689ed2bc2467e26cbda2"
}
